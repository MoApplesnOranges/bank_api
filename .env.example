# MongoDB connection string
# AWS EC2:          mongodb://<EC2-PUBLIC-IP>:27017
# AWS DocumentDB:   mongodb://<user>:<pass>@<cluster>.docdb.amazonaws.com:27017/?tls=true&...
# Local Docker:     mongodb://localhost:27017
MONGO_URL=mongodb://3.91.173.4:27017

