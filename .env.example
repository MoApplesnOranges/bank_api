# Copy this file to .env and fill in your values
# cp .env.example .env

# MongoDB connection string (EC2 instance running MongoDB)
MONGO_URL=mongodb://3.91.173.4:27017

# Optional: extra CORS origin beyond GitHub Pages + localhost
# Useful if you add a custom domain in front of EC2
# CORS_ORIGIN=https://your-custom-domain.com

# ── Frontend (GitHub Actions variable, not this file) ──────────────────────
# Set VITE_API_URL in: GitHub repo → Settings → Variables → Actions
#
# Value format:  https://<EC2-HOST>
# Example:       https://ec2-3-91-173-4.compute-1.amazonaws.com
#                https://52.90.1.2
#
# The browser must accept the self-signed cert once:
#   1. Visit https://<EC2-HOST> in your browser
#   2. Click "Advanced" → "Proceed" to accept the cert warning
#   3. GitHub Pages can then call the API without issues
